{
  "manifest_version": 3,
  "name": "오늘의 활동 분석기",
  "version": "1.0",
  "description": "오늘 내가 어떤 사이트를 얼마나 방문했는지 분석해드립니다.",
  "permissions": ["history", "tabs", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "오늘의 활동 분석기"
  }
}
